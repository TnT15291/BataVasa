{
  "expo": {
    "name": "BataVasa",
    "slug": "batavasa",
    "scheme": "batavasa",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "BataVasa uses your microphone for voice input to quickly add transactions, habits, journal entries, and reminders.",
        "NSFaceIDUsageDescription": "BataVasa uses Face ID to protect your private finance, journal, habit, and reminder data."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.batavasa.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "batavasa",
              "host": "reset-password"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "batavasa"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-av",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "BataVasa uses Face ID to protect your private finance, journal, habit, and reminder data."
        }
      ],
      "expo-router",
      "expo-notifications",
      "@react-native-community/datetimepicker",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "BataVasa uses your location to tag transactions, journal entries, and other activities. You can disable this anytime in Settings."
        }
      ],
      "@sentry/react-native",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "tsconfigPaths": true,
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "privacyPolicyUrl": "https://github.com/TnT15291/BataVasa/blob/main/docs/privacy-policy.md",
      "supportUrl": "https://github.com/TnT15291/BataVasa",
      "eas": {
        "projectId": "be67fd7e-b54b-4646-92fb-04bd104919ee"
      }
    }
  }
}
