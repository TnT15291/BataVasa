{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@features/*": ["./features/*"],
      "@store/*": ["./store/*"],
      "@db/*": ["./database/*"],
      "@services/*": ["./services/*"],
      "@components/*": ["./components/*"],
      "@design/*": ["./design/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
