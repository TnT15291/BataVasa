# Copy to .env.local and fill in. .env*.local is gitignored — never commit real keys.
# See docs/auth-setup.md for how to create a Supabase project and find these values.
# Restart Expo with `npx expo start -c` after editing so the vars are re-bundled.

# Supabase (auth — B1; sync — B2). Use the PROJECT URL + the anon/public key.
# Never put the service_role key here — it must not ship in the client bundle.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Sentry crash reporting (optional in dev). Public DSN only.
EXPO_PUBLIC_SENTRY_DSN=

# dev | preview | prod
EXPO_PUBLIC_ENV=dev
